              "value1": "={{ $json.has_url }}",
              "value2": true
            }
          ]
        },
        "options": {}
      },
      "id": "1639a2e3-c752-4f19-86ba-ad40afab4924",
      "name": "¿Tiene URL?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        13312,
        10176
      ]
    },
    {
      "parameters": {
        "url": "=https://bryan.ecuadev.com/api/properties/resolve-maps-url?url={{ encodeURIComponent($json.urlToFetch) }}",
        "options": {
          "timeout": 4000
        }
      },
      "id": "6acd0fab-52e3-4288-a20c-74a8c54b9d26",
      "name": "HTTP Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        13488,
        10160
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "let p = {};\ntry {\n  let prevItems = $items(\"Extraer URL\");\n  if (prevItems && prevItems.length > 0) {\n    p = JSON.parse(JSON.stringify(prevItems[0].json));\n  } else {\n    p = JSON.parse(JSON.stringify($input.first().json));\n  }\n} catch(e) {\n  p = JSON.parse(JSON.stringify($input.first().json));\n}\n\ntry {\n  const inputItem = $input.first().json;\n  if (inputItem.error) {\n    throw new Error(\"Timeout o Error en API Backend: \" + JSON.stringify(inputItem.error));\n  }\n  if (inputItem.latitude && inputItem.longitude) {\n    p.latitude = inputItem.latitude;\n    p.longitude = inputItem.longitude;\n    p.location_url = inputItem.resolvedUrl || p.urlToFetch;\n  }\n} catch (e) {\n  p.latitude = \"0\";\n  p.longitude = \"0\";\n  p.location_url = \"\";\n  p.error = \"No se pudo guardar la ubicación: Error al resolver Link en el sistema. \" + e.message;\n  p.error_location = p.error;\n}\n\ndelete p.has_url;\ndelete p.urlToFetch;\n\nreturn [{ json: p }];"
      },
      "id": "2490a3f8-f3d2-439c-8ec4-f1fe3fcadf79",
      "name": "Resolver Ubicacion",
      "type": "n8n-nodes-base.code",
