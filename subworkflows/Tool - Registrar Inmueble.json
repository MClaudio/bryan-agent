    {
      "parameters": {
        "jsCode": "const p = $input.first().json;\nlet textToSearch = (p.location_url || \"\") + \" \" + (p.latitude || \"\") + \" \" + (p.longitude || \"\") + \" \" + (p.observations || \"\") + \" \" + (p.direccion_inmueble || \"\") + \" \" + (p.codigo || \"\");\n\nlet match = textToSearch.match(/https?:\\/\\/[^\\s]+/);\nlet urlToFetch = \"\";\n\nif (match) {\n  let foundUrl = match[0];\n  if (foundUrl.includes(\"google\") || foundUrl.includes(\"goo.gl\") || foundUrl.includes(\"maps\")) {\n    urlToFetch = foundUrl;\n  }\n}\n\np.latitude = p.latitude || \"0\";\np.longitude = p.longitude || \"0\";\np.location_url = p.location_url || \"\";\n\nreturn [{ json: { ...p, has_url: urlToFetch !== \"\", urlToFetch } }];"
      },
      "id": "5d0997ab-5c36-44f5-8801-614fcd4e595b",
      "name": "Extraer URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        13168,
        10176
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
