    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO properties (\n  id, code, address, location_url,\n  construction_area, land_area, has_basic_services, basic_services,\n  property_type, topography, zone, status,\n  advisor_id, owner, price, min_price, commission,\n  latitude, longitude,\n  is_public, is_active, is_featured,\n  observations, created_at, updated_at\n) VALUES (\n  gen_random_uuid(), $1, $2, $16,\n  $3, $4, false, '[]',\n  $5, $6, $7, 'Nuevo',\n  $8::uuid, $9, $10, $11, $12,\n  $13, $14,\n  true, true, false,\n  $15, NOW() AT TIME ZONE 'America/Guayaquil', NOW() AT TIME ZONE 'America/Guayaquil'\n) RETURNING id, code, address, property_type, status;",
        "options": {
          "queryReplacement": "={{ [\n  $('Resolver Ubicacion').item.json.codigo,\n  $('Resolver Ubicacion').item.json.direccion_inmueble,\n  $('Resolver Ubicacion').item.json.area_construccion || 0,\n  $('Resolver Ubicacion').item.json.area_terreno || 0,\n  $('Resolver Ubicacion').item.json.property_type || '',\n  $('Resolver Ubicacion').item.json.topography || '',\n  $('Resolver Ubicacion').item.json.zone || '',\n  $('Resolver Ubicacion').item.json.advisor_id,\n  $('Resolver Ubicacion').item.json.owner || '',\n  $('Resolver Ubicacion').item.json.price || 0,\n  $('Resolver Ubicacion').item.json.min_price || 0,\n  $('Resolver Ubicacion').item.json.commission || 0,\n  $('Resolver Ubicacion').item.json.latitude || '0',\n  $('Resolver Ubicacion').item.json.longitude || '0',\n  $('Resolver Ubicacion').item.json.observations || '',\n  $('Resolver Ubicacion').item.json.location_url || ''\n] }}"
        }
      },
      "id": "eee389be-bd14-46d3-96ab-7d0df5ba20d8",
      "name": "Insertar Inmueble",
      "type": "n8n-nodes-base.postgres",
