      "id": "63d8c043-9ea0-499b-b1b2-61fbd0fa7714",
      "name": "Ejecutar Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        -4544,
        -1840
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst propertyCode = items[0].json.property_code;\nconst propertyAddress = items[0].json.property_address;\nconst propertyStatus = items[0].json.property_status;\n\nlet lines = [`📋 *Procesos - Inmueble ${propertyCode}*`, `📍 ${propertyAddress}`, `📊 Estado: ${propertyStatus}`, ''];\n\nitems.forEach((item, i) => {\n  const p = item.json;\n  const updatedDate = new Date(p.updated_at).toLocaleDateString('es-EC', { day: '2-digit', month: '2-digit', year: 'numeric' });\n  lines.push(`*${i + 1}. ${p.title}* (${p.type})`);\n  lines.push(`   📝 ${p.description}`);\n  if (p.next_step) lines.push(`   ➡️ Siguiente: ${p.next_step}`);\n  if (p.approximate_time) lines.push(`   ⏱️ Tiempo: ${p.approximate_time}`);\n  lines.push(`   🗓️ Actualizado: ${updatedDate}`);\n  lines.push(`   🆔 ID: ${p.id}`);\n  lines.push('');\n});\n\nreturn [{ json: { resultado: lines.join('\\n') } }];"
      },
      "id": "3258eb4a-29bf-4d3e-9c3f-483811e63d63",
