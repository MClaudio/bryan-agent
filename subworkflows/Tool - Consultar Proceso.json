  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pr.id,\n  pr.title,\n  pr.type,\n  pr.description,\n  pr.next_step,\n  pr.approximate_time,\n  pr.expenses,\n  pr.created_at,\n  pr.updated_at,\n  p.code AS property_code,\n  p.address AS property_address,\n  p.status AS property_status\nFROM processes pr\nJOIN properties p ON p.id = pr.property_id\nWHERE p.code = $1\n  AND p.is_active = true\nORDER BY pr.updated_at DESC;",
        "options": {}
      },
