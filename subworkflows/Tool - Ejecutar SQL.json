    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\n\n// Redact sensitive fields (passwords, tokens, UUIDs/IDs)\nconst SENSITIVE_EXACT = ['id', 'user_id', 'client_id', 'property_id', 'advisor_id', 'interest_id', 'proceso_id'];\nconst SENSITIVE_CONTAINS = ['password', 'token', 'apikey', 'api_key', 'secret', 'hash'];\n\nconst redact = (obj) => {\n  const out = { ...obj };\n  Object.keys(out).forEach(k => {\n    const kl = k.toLowerCase();\n    const isExact = SENSITIVE_EXACT.includes(kl);\n    const contains = SENSITIVE_CONTAINS.some(s => kl.includes(s));\n    // Any field ending in _id or named exactly 'id'\n    const isId = kl === 'id' || kl.endsWith('_id');\n    if (isExact || contains || isId) {\n      out[k] = '*** [oculto] ***';\n    }\n  });\n  return out;\n};\n\nif (rows.length === 0 || (rows.length === 1 && Object.keys(rows[0]).length === 0)) {\n  return [{ json: { resultado: 'ℹ️ La consulta no devolvió resultados.' } }];\n}\n\nconst clean = rows.map(redact);\nconst preview = clean.slice(0, 15);\nconst truncated = rows.length > 15 ? `\\n_(mostrando 15 de ${rows.length} filas)_` : '';\n\nreturn [{ json: { resultado: `✅ Consulta ejecutada. Filas encontradas: ${rows.length}${truncated}\\n\\`\\`\\`json\\n${JSON.stringify(preview, null, 2)}\\n\\`\\`\\`` } }];"
      },
      "id": "3b4c34e8-1fe1-4977-8ab1-8cad64eceb96",
      "name": "Resultado SQL Inline",
      "type": "n8n-nodes-base.code",
