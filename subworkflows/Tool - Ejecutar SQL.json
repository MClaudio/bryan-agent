      ]
    },
    {
      "parameters": {
        "jsCode": "const q = ($('Ejecutar Workflow').first().json.consulta_sql ?? '').trim();\nconst normalized = q.toLowerCase();\nconst forbidden = ['insert','update','delete','drop','alter','truncate','grant','revoke','create'];\nconst hasForbidden = forbidden.some(w => new RegExp('\\\\b'+w+'\\\\b','i').test(normalized));\nconst isSelect = /^\\s*select\\b/i.test(normalized);\nreturn [{ json: { consulta_sql: q, sql_valida: Boolean(q) && isSelect && !hasForbidden } }];"
      },
