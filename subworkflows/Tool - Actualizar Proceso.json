    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE processes SET description = $1, next_step = COALESCE(NULLIF($2, ''), next_step), approximate_time = COALESCE(NULLIF($3, ''), approximate_time), updated_at = NOW() AT TIME ZONE 'America/Guayaquil' WHERE id = $4::uuid RETURNING id, title, type, description, next_step, approximate_time;",
        "options": {
          "queryReplacement": "={{ [\n  $json.wf_data.description,\n  $json.wf_data.next_step,\n  $json.wf_data.approximate_time,\n  $json.wf_data.proceso_id\n] }}"
        }
