        "query": "INSERT INTO processes (id, property_id, title, type, description, expenses, approximate_time, next_step, created_at, updated_at) VALUES (gen_random_uuid(), $1::uuid, $2, $3, $4, '[]', $5, $6, NOW() AT TIME ZONE 'America/Guayaquil', NOW() AT TIME ZONE 'America/Guayaquil') RETURNING id, title, type, description, next_step;",
        "options": {
          "queryReplacement": "={{ [\n  $json.property_id,\n  $json.wf_data.title,\n  $json.wf_data.type,\n  $json.wf_data.description,\n  $json.wf_data.approximate_time,\n  $json.wf_data.next_step\n] }}"
        }
