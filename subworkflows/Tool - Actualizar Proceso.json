    {
      "parameters": {
        "jsCode": "const wf = $(\"Ejecutar Workflow\").first().json;\nconst propItems = $input.all().map(i => i.json);\nconst propiedades = (propItems.length === 1 && Object.keys(propItems[0]).length === 0) ? [] : propItems;\n\nlet accion = 'accion_valida';\nlet resultado = '';\nlet property_id = null;\n\nif (propiedades.length === 0) {\n  accion = 'error';\n  resultado = `\\n❌ No se encontró ningún inmueble en la base de datos con la dirección o código proporcionado: ${wf.inmueble}.`;\n} else if (propiedades.length > 1) {\n  accion = 'error';\n  resultado = `\\n⚠️ Propiedades encontradas:\\n`;\n  propiedades.forEach(p => {\n    resultado += `- Código: ${p.code} | Dir: ${p.address} | Tipo: ${p.property_type}\\n`;\n  });\n  resultado += `\\n👉 Pide al asesor que confirme el código de la propiedad a la cual desea agregar o actualizar el proceso.`;\n} else {\n  property_id = propiedades[0].id;\n}\n\nreturn [{ json: { accion, resultado, property_id, wf_data: wf } }];"
      },
      "id": "evaluar-inmueble",
      "name": "Evaluar Inmueble",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1720,
