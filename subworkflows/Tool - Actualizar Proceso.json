    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, code, address, status, property_type FROM properties WHERE code ILIKE $1 OR address ILIKE $2 OR $3 ILIKE '%' || address || '%' LIMIT 10;",
        "options": {
          "queryReplacement": "={{ [\n  $('Ejecutar Workflow').item.json.inmueble,\n  '%' + $('Ejecutar Workflow').item.json.inmueble + '%',\n  $('Ejecutar Workflow').item.json.inmueble\n] }}"
        }
      },
      "id": "buscar-inmueble",
      "name": "Buscar Inmueble",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
